---
interface Props {
  size?: number;
}

const { size = 5 } = Astro.props;
---

<span
  class="indicator-dot"
  style={`width: ${size}px; height: ${size}px`}
  aria-hidden="true"
></span>

<style>
  .indicator-dot {
    display: inline-block;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }
</style>
