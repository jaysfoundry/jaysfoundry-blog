---
interface Props {
  size?: 'default' | 'small';
}

const { size = 'default' } = Astro.props;
const height = size === 'small' ? '28px' : '36px';
---

<span class="accent-bar" style={`height: ${height}`}></span>

<style>
  .accent-bar {
    display: inline-block;
    width: 3px;
    background: var(--color-accent);
    border-radius: 1.5px;
    flex-shrink: 0;
  }
</style>
