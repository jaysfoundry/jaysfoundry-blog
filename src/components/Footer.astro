---
import HatchedDivider from './HatchedDivider.astro';
---

<footer>
  <HatchedDivider />
  <div class="footer-content">
    <span class="footer-info">Jay &mdash; Orlando, FL</span>
    <span class="footer-links">
      <a href="https://github.com/jaysfoundry" target="_blank" rel="noopener">GitHub</a>
      <span class="separator">&middot;</span>
      <a href="/rss.xml">RSS</a>
    </span>
  </div>
</footer>

<style>
  footer {
    width: var(--content-width);
    max-width: calc(100% - var(--page-padding) * 2);
    margin: 0 auto;
    padding: 0 0 3rem 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
  }

  .footer-info {
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--color-taupe);
  }

  .footer-links {
    font-size: 12px;
    letter-spacing: 0.5px;
  }

  .footer-links a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .footer-links a:hover {
    text-decoration: underline;
    text-decoration-color: rgba(196, 75, 47, 0.3);
  }

  .separator {
    color: var(--color-taupe);
    margin: 0 0.35em;
  }
</style>
