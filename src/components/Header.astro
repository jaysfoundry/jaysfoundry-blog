---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import IndicatorDot from './IndicatorDot.astro';

interface Props {
  variant?: 'home' | 'post';
  pages?: { title: string; slug: string }[];
}

const { variant = 'home', pages = [] } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const navItems = [
  { label: 'Writing', href: '/' },
  ...pages.map((p) => ({ label: p.title, href: `/${p.slug}` })),
];
---

{variant === 'home' ? (
  <header class="header-home">
    <div class="header-top">
      <div class="brand">
        <a href="/" class="brand-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="monogram">
            <rect width="512" height="512" rx="64" fill="#F0ECE3"/>
            <path d="M84 144 L128 144 L128 310 Q128 376 80 376 L56 376 L56 338 L80 338 Q88 338 88 310 L88 144 Z" fill="#2C2A25"/>
            <path d="M168 144 L332 144 L332 178 L208 178 L208 244 L306 244 L306 278 L208 278 L208 374 L168 374 Z" fill="#2C2A25"/>
            <circle cx="390" cy="348" r="42" fill="none" stroke="#8B7E6A" stroke-width="8" opacity="0.4"/>
            <circle cx="390" cy="348" r="24" fill="#E8E3D9"/>
            <rect x="386" y="298" width="8" height="24" rx="4" fill="#C44B2F"/>
            <rect x="56" y="444" width="400" height="4" rx="2" fill="#C44B2F"/>
            <rect x="56" y="456" width="400" height="4" rx="2" fill="#C44B2F" opacity="0.5"/>
          </svg>
        </a>
        <div class="brand-text">
          <a href="/" class="brand-name">{SITE_TITLE}</a>
          <span class="tagline">{SITE_DESCRIPTION}</span>
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="header-icon" aria-hidden="true">
        <rect width="512" height="512" rx="64" fill="#F0ECE3"/>
        <rect x="120" y="192" width="180" height="16" rx="8" fill="#8B7E6A"/>
        <rect x="120" y="240" width="180" height="16" rx="8" fill="#8B7E6A" opacity="0.7"/>
        <rect x="120" y="288" width="180" height="16" rx="8" fill="#8B7E6A" opacity="0.4"/>
        <circle cx="368" cy="256" r="56" fill="#C44B2F"/>
      </svg>
    </div>
    <nav class="nav-home">
      {navItems.map((item) => {
        const isActive = item.href === pathname || (item.href !== '/' && pathname.startsWith(item.href));
        const isWritingActive = item.href === '/' && (pathname === '/' || pathname.startsWith('/blog'));
        const active = isActive || isWritingActive;
        return (
          <a href={item.href} class:list={['nav-link', { active }]}>
            {active && <IndicatorDot />}
            {item.label}
          </a>
        );
      })}
    </nav>
  </header>
) : (
  <header class="header-post">
    <div class="header-row">
      <div class="brand">
        <a href="/" class="brand-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="24" height="24" class="monogram">
            <rect width="512" height="512" rx="64" fill="#F0ECE3"/>
            <path d="M84 144 L128 144 L128 310 Q128 376 80 376 L56 376 L56 338 L80 338 Q88 338 88 310 L88 144 Z" fill="#2C2A25"/>
            <path d="M168 144 L332 144 L332 178 L208 178 L208 244 L306 244 L306 278 L208 278 L208 374 L168 374 Z" fill="#2C2A25"/>
            <circle cx="390" cy="348" r="42" fill="none" stroke="#8B7E6A" stroke-width="8" opacity="0.4"/>
            <circle cx="390" cy="348" r="24" fill="#E8E3D9"/>
            <rect x="386" y="298" width="8" height="24" rx="4" fill="#C44B2F"/>
            <rect x="56" y="444" width="400" height="4" rx="2" fill="#C44B2F"/>
            <rect x="56" y="456" width="400" height="4" rx="2" fill="#C44B2F" opacity="0.5"/>
          </svg>
        </a>
        <a href="/" class="brand-name small">{SITE_TITLE}</a>
      </div>
      <a href="/" class="back-link">&larr; Writing</a>
    </div>
  </header>
)}

<style>
  /* Shared */
  header {
    width: var(--content-width);
    max-width: calc(100% - var(--page-padding) * 2);
    margin: 0 auto;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-icon {
    display: flex;
    flex-shrink: 0;
    line-height: 0;
  }

  .header-icon {
    width: 50px;
    height: 50px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .header-home .monogram {
    width: 50px;
    height: 50px;
    border-radius: 6px;
  }

  .header-post .monogram {
    width: 24px;
    height: 24px;
    border-radius: 4px;
  }

  .brand-name {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.2px;
    color: var(--color-ink);
    text-decoration: none;
  }

  .brand-name:hover {
    text-decoration: none;
    color: var(--color-ink);
  }

  .brand-name.small {
    font-size: 16px;
  }

  /* Home header */
  .header-home {
    padding-top: 2.5rem;
    padding-bottom: 0;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .tagline {
    font-size: 13px;
    letter-spacing: 1.5px;
    color: var(--color-taupe);
    text-transform: uppercase;
    margin-top: 2px;
  }

  .nav-home {
    display: flex;
    gap: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(139, 126, 106, 0.2);
    margin-bottom: 2rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    letter-spacing: 0.3px;
    text-decoration: none;
    color: var(--color-taupe);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Post header */
  .header-post {
    padding-top: 2rem;
    padding-bottom: 1.5rem;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    font-size: 13px;
    letter-spacing: 0.3px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
    text-decoration-color: rgba(196, 75, 47, 0.3);
  }
</style>
