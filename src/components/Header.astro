---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import IndicatorDot from './IndicatorDot.astro';

interface Props {
  variant?: 'home' | 'post';
  pages?: { title: string; slug: string }[];
}

const { variant = 'home', pages = [] } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const navItems = [
  { label: 'Writing', href: '/' },
  ...pages.map((p) => ({ label: p.title, href: `/${p.slug}` })),
];
---

{variant === 'home' ? (
  <header class="header-home">
    <div class="header-top">
      <div class="brand">
        <div class="accent-bar" aria-hidden="true"></div>
        <div class="brand-text">
          <a href="/" class="brand-name">{SITE_TITLE}</a>
          <span class="tagline">{SITE_DESCRIPTION}</span>
          <div class="brand-motifs" aria-hidden="true">
            <svg viewBox="0 0 6 20" class="bm bm-bar"><rect width="6" height="20" rx="3" fill="#C44B2F"/></svg>
            <svg viewBox="0 0 36 24" class="bm bm-grill-ind">
              <circle cx="5" cy="5" r="3.5" fill="#8B7E6A" opacity="0.4"/>
              <circle cx="18" cy="5" r="3.5" fill="#8B7E6A" opacity="0.4"/>
              <circle cx="31" cy="5" r="3.5" fill="#C44B2F" opacity="0.6"/>
              <circle cx="5" cy="19" r="3.5" fill="#8B7E6A" opacity="0.3"/>
              <circle cx="18" cy="19" r="3.5" fill="#8B7E6A" opacity="0.3"/>
              <circle cx="31" cy="19" r="3.5" fill="#8B7E6A" opacity="0.3"/>
            </svg>
            <svg viewBox="0 0 24 24" class="bm bm-dial">
              <circle cx="12" cy="12" r="10.5" fill="none" stroke="#8B7E6A" stroke-width="1.5" opacity="0.5"/>
              <circle cx="12" cy="12" r="7" fill="#E8E3D9"/>
              <rect x="11" y="0" width="2" height="5" rx="1" fill="#C44B2F"/>
            </svg>
            <svg viewBox="0 0 32 20" class="bm bm-lines">
              <rect y="0" width="32" height="3" rx="1.5" fill="#8B7E6A" opacity="0.4"/>
              <rect y="8.5" width="32" height="3" rx="1.5" fill="#8B7E6A" opacity="0.3"/>
              <rect y="17" width="32" height="3" rx="1.5" fill="#8B7E6A" opacity="0.2"/>
            </svg>
            <svg viewBox="0 0 10 10" class="bm bm-dot"><circle cx="5" cy="5" r="5" fill="#C44B2F" opacity="0.5"/></svg>
            <svg viewBox="0 0 36 24" class="bm bm-grill-ind">
              <circle cx="5" cy="5" r="3.5" fill="#8B7E6A" opacity="0.3"/>
              <circle cx="18" cy="5" r="3.5" fill="#8B7E6A" opacity="0.3"/>
              <circle cx="31" cy="5" r="3.5" fill="#8B7E6A" opacity="0.3"/>
              <circle cx="5" cy="19" r="3.5" fill="#8B7E6A" opacity="0.4"/>
              <circle cx="18" cy="19" r="3.5" fill="#8B7E6A" opacity="0.4"/>
              <circle cx="31" cy="19" r="3.5" fill="#C44B2F" opacity="0.6"/>
            </svg>
            <svg viewBox="0 0 6 20" class="bm bm-bar"><rect width="6" height="20" rx="3" fill="#C44B2F" opacity="0.4"/></svg>
          </div>
        </div>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="header-icon" aria-hidden="true">
        <rect width="512" height="512" rx="64" fill="#F0ECE3"/>
        <rect x="128" y="240" width="12" height="48" rx="6" fill="#8B7E6A" opacity="0.4"/>
        <rect x="172" y="224" width="12" height="64" rx="6" fill="#8B7E6A" opacity="0.55"/>
        <rect x="216" y="208" width="12" height="80" rx="6" fill="#8B7E6A" opacity="0.7"/>
        <rect x="250" y="188" width="12" height="100" rx="6" fill="#C44B2F"/>
        <rect x="284" y="208" width="12" height="80" rx="6" fill="#8B7E6A" opacity="0.7"/>
        <rect x="328" y="224" width="12" height="64" rx="6" fill="#8B7E6A" opacity="0.55"/>
        <rect x="372" y="240" width="12" height="48" rx="6" fill="#8B7E6A" opacity="0.4"/>
      </svg>
    </div>
    <nav class="nav-home">
      {navItems.map((item) => {
        const isActive = item.href === pathname || (item.href !== '/' && pathname.startsWith(item.href));
        const isWritingActive = item.href === '/' && (pathname === '/' || pathname.startsWith('/blog'));
        const active = isActive || isWritingActive;
        return (
          <a href={item.href} class:list={['nav-link', { active }]}>
            {active && <IndicatorDot />}
            {item.label}
          </a>
        );
      })}
    </nav>
  </header>
) : (
  <header class="header-post">
    <div class="header-row">
      <div class="brand">
        <a href="/" class="brand-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="24" height="24" class="monogram">
            <rect width="512" height="512" rx="64" fill="#F0ECE3"/>
            <path d="M84 144 L128 144 L128 310 Q128 376 80 376 L56 376 L56 338 L80 338 Q88 338 88 310 L88 144 Z" fill="#2C2A25"/>
            <path d="M168 144 L332 144 L332 178 L208 178 L208 244 L306 244 L306 278 L208 278 L208 374 L168 374 Z" fill="#2C2A25"/>
            <circle cx="390" cy="348" r="42" fill="none" stroke="#8B7E6A" stroke-width="8" opacity="0.4"/>
            <circle cx="390" cy="348" r="24" fill="#E8E3D9"/>
            <rect x="386" y="298" width="8" height="24" rx="4" fill="#C44B2F"/>
            <rect x="56" y="444" width="400" height="4" rx="2" fill="#C44B2F"/>
            <rect x="56" y="456" width="400" height="4" rx="2" fill="#C44B2F" opacity="0.5"/>
          </svg>
        </a>
        <a href="/" class="brand-name small">{SITE_TITLE}</a>
      </div>
      <a href="/" class="back-link">&larr; Writing</a>
    </div>
  </header>
)}

<style>
  /* Shared */
  header {
    width: var(--content-width);
    max-width: calc(100% - var(--page-padding) * 2);
    margin: 0 auto;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .accent-bar {
    width: 3px;
    align-self: stretch;
    background: var(--color-accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .header-icon {
    width: 64px;
    height: 64px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .brand-name {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.2px;
    color: var(--color-ink);
    text-decoration: none;
  }

  .brand-name:hover {
    text-decoration: none;
    color: var(--color-ink);
  }

  .brand-name.small {
    font-size: 16px;
  }

  /* Home header */
  .header-home {
    padding-top: 2.5rem;
    padding-bottom: 0;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .tagline {
    font-size: 13px;
    letter-spacing: 1.5px;
    color: var(--color-taupe);
    text-transform: uppercase;
    margin-top: 2px;
  }

  .brand-motifs {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
    opacity: 0.7;
  }

  .bm-bar { width: 3px; height: 12px; }
  .bm-grill-ind { width: 18px; height: 14px; }
  .bm-dial { width: 13px; height: 13px; }
  .bm-lines { width: 18px; height: 12px; }
  .bm-dot { width: 5px; height: 5px; }

  .nav-home {
    display: flex;
    gap: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(139, 126, 106, 0.2);
    margin-bottom: 2rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 15px;
    letter-spacing: 0.3px;
    text-decoration: none;
    color: var(--color-taupe);
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Post header */
  .header-post {
    padding-top: 2rem;
    padding-bottom: 1.5rem;
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    font-size: 13px;
    letter-spacing: 0.3px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
    text-decoration-color: rgba(196, 75, 47, 0.3);
  }
</style>
