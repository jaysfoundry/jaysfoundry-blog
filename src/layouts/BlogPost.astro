---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HatchedDivider from '../components/HatchedDivider.astro';

interface Props extends CollectionEntry<'blog'>['data'] {
  readingTime?: number;
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
  pages?: { title: string; slug: string }[];
}

const { title, description, pubDate, updatedDate, tags, readingTime, prevPost, nextPost, pages = [] } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header variant="post" pages={pages} />
    <main>
      <article>
        <div class="post-meta">
          <span class="meta-line">
            <FormattedDate date={pubDate} />
            {readingTime && <span> &middot; {readingTime} min read</span>}
          </span>
          {updatedDate && (
            <span class="updated">Updated <FormattedDate date={updatedDate} /></span>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag: string, tagIndex: number) => (
              <span class:list={['tag', { 'tag-accent': tagIndex % 2 === 0 }]}>{tag}</span>
            ))}
          </div>
        )}
        <div class="prose">
          <slot />
        </div>
      </article>

      {(prevPost || nextPost) && (
        <div class="post-nav-wrapper">
          <HatchedDivider />
          <nav class="post-nav">
            <div class="post-nav-item prev">
              {prevPost && (
                <>
                  <span class="post-nav-label">&larr; Previous</span>
                  <a href={`/blog/${prevPost.slug}/`} class="post-nav-title">{prevPost.title}</a>
                </>
              )}
            </div>
            <div class="post-nav-item next">
              {nextPost && (
                <>
                  <span class="post-nav-label">Next &rarr;</span>
                  <a href={`/blog/${nextPost.slug}/`} class="post-nav-title">{nextPost.title}</a>
                </>
              )}
            </div>
          </nav>
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  .post-meta {
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--color-taupe);
    margin-bottom: 0.75rem;
  }

  .updated {
    display: block;
    font-style: italic;
    margin-top: 0.25rem;
  }

  .post-title {
    font-size: 26px;
    font-weight: 400;
    letter-spacing: -0.3px;
    line-height: 1.3;
    color: var(--color-ink);
    margin: 0 0 1rem 0;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-taupe);
    border: 1px solid rgba(139, 126, 106, 0.25);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .tag-accent {
    color: var(--color-accent);
    border-color: rgba(196, 75, 47, 0.3);
  }

  .prose {
    margin-top: 1.5rem;
  }

  /* Post navigation */
  .post-nav-wrapper {
    margin-top: 3rem;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    padding-top: 1.25rem;
    gap: 2rem;
  }

  .post-nav-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-width: 45%;
  }

  .post-nav-item.next {
    text-align: right;
    margin-left: auto;
  }

  .post-nav-label {
    font-size: 11px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-taupe);
  }

  .post-nav-title {
    font-size: 15px;
    color: var(--color-accent);
    text-decoration: none;
    line-height: 1.4;
  }

  .post-nav-title:hover {
    text-decoration: underline;
    text-decoration-color: rgba(196, 75, 47, 0.3);
  }
</style>
