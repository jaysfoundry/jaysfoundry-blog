---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HatchedDivider from '../components/HatchedDivider.astro';
import IndicatorDot from '../components/IndicatorDot.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const pages = (await getCollection('pages')).map((p) => ({
  title: p.data.title,
  slug: p.id,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header pages={pages} />
    <main>
      <ul class="post-list">
        {posts.map((post, index) => (
          <li class="post-item">
            <div class="post-date">
              <FormattedDate date={post.data.pubDate} />
              {index === 0 && (
                <div class="latest-dot">
                  <IndicatorDot size={6} />
                </div>
              )}
            </div>
            <div class="post-content">
              <a href={`/blog/${post.id}/`} class="post-title">
                {post.data.title}
              </a>
              {post.data.description && (
                <p class="post-description">{post.data.description}</p>
              )}
              {post.data.tags && post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string, tagIndex: number) => (
                    <span class:list={['tag', { 'tag-accent': tagIndex % 2 === 0 }]}>
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
    </main>
    <HatchedDivider />
    <Footer />
  </body>
</html>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(139, 126, 106, 0.15);
  }

  .post-item:last-child {
    border-bottom: none;
  }


  .post-date {
    min-width: 48px;
    text-align: right;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--color-taupe);
    padding-top: 3px;
    flex-shrink: 0;
  }

  .latest-dot {
    display: flex;
    justify-content: flex-end;
    margin-top: 6px;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-title {
    font-size: 18px;
    letter-spacing: -0.1px;
    font-weight: 400;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.15s ease;
    line-height: 1.4;
  }

  .post-title:hover {
    color: var(--color-accent);
  }

  .post-description {
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-taupe-light);
    margin: 0.35rem 0 0 0;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 11px;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--color-taupe);
    border: 1px solid rgba(139, 126, 106, 0.25);
    padding: 2px 8px;
    border-radius: 2px;
  }

  .tag-accent {
    color: var(--color-accent);
    border-color: rgba(196, 75, 47, 0.3);
  }
</style>
