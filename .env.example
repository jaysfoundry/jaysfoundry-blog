# Jay's Foundry Blog — Environment Variables
# Copy to .env and fill in values

# Site URL (used by Astro for canonical URLs, sitemap, RSS)
# SITE_URL=https://jaysfoundry.com

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Set in Vercel for production. Leave unset locally to skip tracking in dev.
# PUBLIC_GA_MEASUREMENT_ID=
